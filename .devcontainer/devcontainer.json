ip{
	"name": "Python 3",
	"image": "mcr.microsoft.com/devcontainers/python:3-3.12-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/python:1": {}
	},

	// Instala extensões úteis direto no container
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"ms-toolsai.jupyter-renderers"
			]
		}
	},

	// Instala o kernel do Jupyter e bibliotecas básicas assim que o container subir
	"postCreateCommand": "pip3 install ipykernel jupyter pandas matplotlib"

	// "remoteUser": "root"
}